# Copy this file to `.env` and adjust (optional for local dev).
# On Windows (PowerShell): $env:DJANGO_SECRET_KEY="your-long-random-string"
# Never commit a real `.env` file.

# Long random string for sessions/cookies; required for any shared or production host.
# DJANGO_SECRET_KEY=

# Use False only behind a proper HTTPS reverse proxy in production.
# DJANGO_DEBUG=True
